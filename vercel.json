{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "functions": {
    "api/**/*": {
      "includeFiles": "{*.png,*.pdf}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(badges|projects|public|admin|register|send-welcome-emails)(/.*)?",
      "destination": "/api"
    },
    {
      "source": "/api(/)?",
      "destination": "/api"
    },
    {
      "source": "/api/(.*)",
      "destination": "/404"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
